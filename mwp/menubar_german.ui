<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <menu id="menubar">
    <submenu>
      <attribute name="label">_Feile</attribute>
      <section>
        <item>
          <attribute name="label">Öffnen Sie Mission</attribute>
          <attribute name="action">win.file-open</attribute>
	  <attribute name="accel">&lt;Primary&gt;m</attribute>
        </item>
        <item>
          <attribute name="label">Außer Mission</attribute>
          <attribute name="action">win.menu-save</attribute>
        </item>
        <item>
          <attribute name="label">Außer Mission wie</attribute>
          <attribute name="action">win.menu-save-as</attribute>
        </item>
      </section>
      <section>
        <item>
          <attribute name="label">Antriebskraft-Mission</attribute>
          <attribute name="action">win.upload-mission</attribute>
	  <attribute name="accel">&lt;Primary&gt;u</attribute>
        </item>
        <item>
          <attribute name="label">Mission herunterladen</attribute>
          <attribute name="action">win.download-mission</attribute>
	  <attribute name="tooltip">Download from FC</attribute>
	</item>
      </section>
      <section>
        <item>
          <attribute name="label">Wiederherstellung Mission von EEPROM</attribute>
          <attribute name="action">win.restore-mission</attribute>
	  <attribute name="accel">&lt;Primary&gt;r</attribute>
        </item>
        <item>
          <attribute name="label">Außer Mission zu EEPROM</attribute>
          <attribute name="action">win.store-mission</attribute>
	  <attribute name="accel">&lt;Primary&gt;e</attribute>
	</item>
      </section>
      <section>
        <item>
          <attribute name="label">Wiederholen MWP Log</attribute>
          <attribute name="action">win.replay-log</attribute>
        </item>
        <item>
          <attribute name="label">Laden das MWP Log</attribute>
          <attribute name="action">win.load-log</attribute>
	</item>
      </section>
      <section>
        <item>
          <attribute name="label">Wiederholen blackbox Maschinenbordbuch</attribute>
          <attribute name="action">win.replay-bb</attribute>
        </item>
        <item>
          <attribute name="label">Laden blackbox Maschinenbordbuch</attribute>
          <attribute name="action">win.load-bb</attribute>
	  <link name="loadbb" id="loadbb"></link>
	</item>
      </section>
      <section>
        <item>
          <attribute name="label">Stoppen Sie die Wiedergabe</attribute>
          <attribute name="action">win.stop-replay</attribute>
	  <link name="loadbb" id="loadbb"></link>
	</item>
      </section>
      <section>
	<submenu>
        <attribute name="label">Statische Testblätter</attribute>
	<section>
          <item>
            <attribute name="label">Laden</attribute>
            <attribute name="action">win.kml-load</attribute>
          </item>
          <item>
            <attribute name="label">Löschen</attribute>
            <attribute name="action">win.kml-remove</attribute>
          </item>
	</section>
      </submenu>
      </section>

      <section>
        <item>
          <attribute name="label">Verlassen</attribute>
	  <attribute name="accel">&lt;Primary&gt;q</attribute>
          <attribute name="action">app.quit</attribute>
        </item>
      </section>
    </submenu>
    <submenu>
      <attribute name="label">_Verlassen</attribute>
      <section>
        <item>
          <attribute name="label">Verlassen</attribute>
          <attribute name="action">win.prefs</attribute>
	  <attribute name="accel">&lt;Primary&gt;p</attribute>
        </item>
        <item>
          <attribute name="label">CLI Terminal</attribute>
          <attribute name="action">win.terminal</attribute>
	  <attribute name="accel">&lt;Shift&gt;t</attribute>
        </item>
        <item>
          <attribute name="label">Nav Config</attribute>
          <attribute name="action">win.navconfig</attribute>
        </item>
        <item>
          <attribute name="label">Erhalten Mission</attribute>
          <attribute name="action">win.mission-info</attribute>
        </item>
        <item>
          <attribute name="label">Samenkarte</attribute>
          <attribute name="action">win.seed-map</attribute>
        </item>
        <item>
          <attribute name="label">Neustarten FC</attribute>
          <attribute name="action">win.reboot</attribute>
	  <attribute name="accel">&lt;Primary&gt;exclam</attribute>
        </item>
        <item>
          <attribute name="label">Audio Test</attribute>
          <attribute name="action">win.audio</attribute>
        </item>
      </section>
    </submenu>
    <submenu>
      <attribute name="label">A_ussicht</attribute>
      <section>
        <item>
          <attribute name="label">Zentrum Mission</attribute>
          <attribute name="action">win.recentre</attribute>
        </item>
        <item>
          <attribute name="label">Standard festlegen</attribute>
          <attribute name="action">win.defloc</attribute>
        </item>
        <item>
          <attribute name="label">Auf Position zentrieren</attribute>
          <attribute name="action">win.centre-on</attribute>
        </item>
        <item>
          <attribute name="label">Kartenquelle</attribute>
          <attribute name="action">win.map-source</attribute>
        </item>
      </section>
      <section>
        <item>
          <attribute name="label">GPS Statistiken</attribute>
          <attribute name="action">win.gps-stats</attribute>
	  <attribute name="accel">&lt;Primary&gt;g</attribute>
        </item>
      </section>
      <section>
        <item>
          <attribute name="label">Missionsliste</attribute>
          <attribute name="action">win.mission-list</attribute>
        </item>
        <item>
          <attribute name="label">Nav Status</attribute>
          <attribute name="action">win.nav-status</attribute>
        </item>
        <item>
          <attribute name="label">GPS Status</attribute>
          <attribute name="action">win.gps-status</attribute>
        </item>
        <item>
          <attribute name="label">Radio Status</attribute>
          <attribute name="action">win.radio-status</attribute>
        </item>
        <item>
          <attribute name="label">Battery Monitor</attribute>
          <attribute name="action">win.bat-mon</attribute>
        </item>
        <item>
          <attribute name="label">Telemetry Status</attribute>
          <attribute name="action">win.tel-stats</attribute>
        </item>
        <item>
          <attribute name="label">Künstlicher Horizont</attribute>
          <attribute name="action">win.art-hor</attribute>
        </item>
        <item>
          <attribute name="label">Richtungsansicht</attribute>
          <attribute name="action">win.direction-view</attribute>
        </item>
        <item>
          <attribute name="label">Flugansicht</attribute>
          <attribute name="action">win.flight-view</attribute>
        </item>
        <item>
          <attribute name="label">Radaransicht</attribute>
          <attribute name="action">win.radar-view</attribute>
        </item>
      </section>
      <section>
        <item>
          <attribute name="label">Flight Statistiken</attribute>
          <attribute name="action">win.flight-stats</attribute>
	  <attribute name="accel">&lt;Primary&gt;a</attribute>
        </item>
      </section>
      <submenu>
        <attribute name="label">Layout Manager</attribute>
	<section>
          <item>
            <attribute name="label">Storen</attribute>
            <attribute name="action">win.layout-save</attribute>
          </item>
          <item>
            <attribute name="label">wiederherstellen</attribute>
            <attribute name="action">win.layout-restore</attribute>
          </item>
	</section>
      </submenu>
    </submenu>
    <submenu>
      <attribute name="label">Hilfe</attribute>
      <section>
        <item>
          <attribute name="label">Liste der Tastenkombinationen</attribute>
          <attribute name="action">win.keys</attribute>
        </item>
        <item>
          <attribute name="label">Über</attribute>
          <attribute name="action">win.about</attribute>
        </item>
      </section>
    </submenu>
  </menu>
  <menu id="appmenu">
    <section>
      <item>
        <attribute name="label">Verlassen</attribute>
        <attribute name="action">app.quit</attribute>
      </item>
    </section>
  </menu>
</interface>
